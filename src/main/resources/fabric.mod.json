{
  "schemaVersion": 1,
  "id": "boss-pvp",
  "version": "${version}",
  "name": "Boss's PVP",
  "description": "The best PvP addon for 2b2t | @WaterBoss11",
  "authors": [
    "WaterBoss11"
  ],
  "license": "GPL-3.0",
  "custom": {
    "autism:color": "255,90,53",
    "modmenu": {
      "parent": {
        "id": "autism"
      }
    }
  },
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.boss.pvp.BossPvpInit"
    ],
    "autism": [
      "com.boss.pvp.BossPvpAddon"
    ]
  },
  "mixins": [
