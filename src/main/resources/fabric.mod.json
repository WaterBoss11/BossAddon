{
  "schemaVersion": 1,
  "id": "bossaddon",
  "provides": ["boss-pvp"],
  "version": "${version}",
  "name": "BossAddon",
  "description": "PvP + utility addon for 2b2t — the merged home of Boss's PVP and BossUtility | @WaterBoss11",
  "authors": [
    "WaterBoss11"
  ],
  "license": "GPL-3.0",
  "custom": {
    "autism:color": "255,90,53",
    "modmenu": {
      "parent": {
        "id": "autism"
      }
    }
  },
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.boss.pvp.BossPvpInit",
      "com.boss.pvp.BossAddonInit"
    ],
    "autism": [
      "com.boss.pvp.BossPvpAddon",
      "com.boss.utility.BossUtilityAddon"
    ]
  },
  "mixins": [
    "boss-pvp.mixins.json",
    "boss-utility.mixins.json"
  ],
  "depends": {
    "java": ">=25",
    "minecraft": "${mc_compat}",
    "fabricloader": ">=0.18.4",
    "fabric-api": "*",
    "autism": ">=2.3"
  }
}
